          { nome: 'ALAMBRADO', subItem: 'TELA DE ARAME (M²)', options: ["INSTALAÇÃO", "AMARRAÇÃO", "TROCA", "REMOÇÃO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA"] },
          { nome: 'ALAMBRADO', subItem: 'TUBOS (M)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
