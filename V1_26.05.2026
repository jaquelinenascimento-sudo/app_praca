          { nome: 'CERCAS/CERCAMENTO', subItem: 'GRADE EXTERNA (Metal)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'CERCAS/CERCAMENTO', subItem: 'PORTÃO DE ACESSO (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] }
        ] 
      },
      { 
        id: 'cat-2', 
        categoria: 'Mobiliário Urbano', 
        itens: [
          { nome: 'BANCO', subItem: 'BANCO DE CONCRETO (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "PINTURA", "REMOÇÃO"] },
          { nome: 'BANCO', subItem: 'BANCO DE TRONCO (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "ENVERNIZAMENTO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BANCO', subItem: 'BANCO DE MADEIRA/FERRO (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'MESA/JARDINEIRA', subItem: 'MESA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "PINTURA", "REMOÇÃO"] },
          { nome: 'MESA/JARDINEIRA', subItem: 'JARDINEIRA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'PARCÃO', options: ["INSTALAÇÃO", "REPARO", "TROCA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'PNEU (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'PORTÃO', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'POSTE', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'FRADE', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'GRADIL', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'MOBILIÁRIOS', subItem: 'GRAMPO', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] }
        ] 
      },
      { 
        id: 'cat-3', 
        categoria: 'Brinquedos (Playground)', 
        itens: [
          { nome: 'BALANÇO', subItem: 'ESTRUTURA DE MADEIRA', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "ENVERNIZAMENTO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BALANÇO', subItem: 'ESTRUTURA DE METAL', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BALANÇO', subItem: 'ASSENTO', options: ["INSTALAÇÃO", "REPARO", "TROCA", "REMOÇÃO"] },
          { nome: 'BALANÇO', subItem: 'CORRENTE', options: ["INSTALAÇÃO", "REPARO", "TROCA", "REMOÇÃO"] },
          { nome: 'GANGORRA', subItem: 'ESTRUTURA/MADEIRA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "ENVERNIZAMENTO", "PINTURA", "REMOÇÃO"] },
          { nome: 'ESCORREGADOR', subItem: 'ESCORREGADOR DE EUCALIPTO (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "ENVERNIZAMENTO", "PINTURA", "REMOÇÃO"] },
          { nome: 'GIRA-GIRA', subItem: 'GIRA-GIRA DE METAL (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BRINQUEDOS DE EUCALIPTO', subItem: 'BRINQUEDO DE EUCALIPTO', options: ["INSTALAÇÃO", "REPARO", "TROCA", "RASPAGEM", "ENVERNIZAMENTO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BRINQUEDOS DE METAL', subItem: 'BRINQUEDO DE METAL', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] }
        ] 
      },
      { 
        id: 'cat-4', 
        categoria: 'Áreas Coletivas & Esportes', 
        itens: [
          { nome: 'QUADRAS ESPORTIVAS', subItem: 'AREIA (M³)', options: ["INSTALAÇÃO", "REPARO", "REMOÇÃO"] },
          { nome: 'QUADRAS ESPORTIVAS', subItem: 'BALIZA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'QUADRAS ESPORTIVAS', subItem: 'CIMENTO (M³)', options: ["INSTALAÇÃO", "MARCAÇÃO", "PINTURA", "REPARO", "REMOÇÃO"] },
          { nome: 'QUADRAS ESPORTIVAS', subItem: 'GRAMA SINTÉTICA (M²)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "REMOÇÃO"] },
          { nome: 'QUADRAS ESPORTIVAS', subItem: 'SAIBRO (M³)', options: ["INSTALAÇÃO", "REPARO", "REMOÇÃO"] },
          { nome: 'BALIZA', subItem: 'BALIZA DE METAL/MADEIRA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'BALIZA', subItem: 'REDE DE BALIZA (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "REMOÇÃO"] },
          { nome: 'TABELA DE BASQUETE', subItem: 'TABELA E ARO DE BASQUETE (UN)', options: ["INSTALAÇÃO", "REPARO", "TROCA", "SOLDA", "RASPAGEM", "LIXAMENTO", "APLICAÇÃO DE ANTICORROSIVO", "PINTURA", "REMOÇÃO"] },
          { nome: 'PISO', subItem: 'PISO DE SAIBRO/GRAMA', options: ["INSTALAÇÃO", "REPARO", "REMOÇÃO"] }
        ] 
      }
    ];

    // --- LISTAGEM COMPLETA EXTRAÍDA DO ARQUIVO PLANILHA 2 DO USUÁRIO ---
    const SERVICOS_LIST = [
      "PINTURA", "ADIADO POR: CHUVA", "ALVENARIA", "AMARRACAO", "APLICACAO DE ANTICORROSIVO", 
      "CHUMBAMENTO", "ENVERNIZAMENTO", "ESCAVACAO", "INSTALACAO", "JARDINAGEM", "LIXAMENTO", 
      "OUTROS", "PLANTIO", "RASPAGEM", "REMOCAO", "REPARO", "SOLDA"
    ];

    const ITENS_LIST = [
      "BARRA FIXA", "ALAMBRADO", "BALANCO DE EUCALIPTO", "BALANCO DE METAL (FABRICA)", "BALIZA", 
      "BANCO DE 1 ASSENTO DE CONCRETO", "BANCO DE 1 ASSENTO DE TRONCO", "BANCO DE ARQUIBANCADA", 
      "BANCO DE METAL", "BANCO EXTENSIVEL", "BANCO LONGO DE CONCRETO", "BANCO LONGO DE RIPA", 
      "BANCO LONGO DE TRONCO", "BARRA DE CALISTENIA", "BARRA DE SALTO (PARCAO)", "BARRA PARALELA", 
      "BICICLETARIO", "MURETA", "MURO", "PARCAO", "PERGOLADO", "PILAR / COLUNA", "PISO DE CONCRETO", 
      "PISO EMBORRACHADO", "PISO GRAMADO", "PISTA DE OBSTACULOS", "PISTA DE PATINS", "PISTA DE SKATE", 
      "PLATAFORMA DE EQUILIBRIO", "PLATAFORMA DE MADEIRA (PARCAO)", "PLAYGROUND DE EUCALIPTO", 
      "PNEU", "PORTAO", "POSTE", "PRANCHA DE ABDOMINAL", "PRANCHA DE EQUILIBRIO (PARCAO)"
    ];

    const MATERIAIS_LIST = [
      "TINTA ESMALTE SINTETICO - AZUL", "ALCA DE GANGORRA", "ANILHA MANILHA", "ARAME GALVANIZADO", 
      "AREIA LAVADA", "AREOLA", "ARO DE BASQUETE", "ARRUELA", "ARRUELA DE ACO INOX 3/8", 
      "ARRUELA LISA EM FERRO 5/16", "ASSENTO DE BALANCO", "BALANCO DE EUCALIPTO", 
      "BALANCO DE METAL (FABRICA)", "BANCO DE CONCRETO", "BARRA REDONDA 1/2 (CM)", "ABRACADEIRA", 
      "BROXA RETANGULAR", "ROLO DE LA 9 CM", "SAIBRO", "SUPORTE P/ ROLO DE 23CM (TIPO GAIOLA)", 
      "TABELA DE BASQUETE", "TELA GALVANIZADA 30M²", "TINTA ACRILICO - AMARELO", "TINTA ACRILICO - AZUL", 
      "TINTA ACRILICO - BRANCO", "TINTA ACRILICO - CINZA", "TINTA ACRILICO - CONCRETO", 
      "TINTA ACRILICO - LARANJA", "TINTA ACRILICO - MARROM", "TINTA ACRILICO - PRETO", 
      "TINTA ACRILICO - VERDE", "TINTA ACRILICO - VERMELHO", "TINTA ESMALTE SINTETICO - AMARELO", 
      "TINTA ESMALTE SINTETICO - BRANCO", "TINTA ESMALTE SINTETICO - CINZA", "TINTA ESMALTE SINTETICO - CONCRETO"
    ];

    function App() {
      // --- SISTEMA DE SELEÇÃO DE ABAS ---
      // 'split' = Celular + Painel de Dados
      // 'desktop' = Tela Inteira de Computador (Mesa)
      const [workspaceTab, setWorkspaceTab] = useState('split'); 

      // --- ESTADOS GLOBAIS UNIFICADOS ---
      const [step, setStep] = useState(1); // Usado exclusivamente no fluxo Mobile
      
      // 1. Tipo de Entrada, Data da Execução e Nova Intervenção
      const [tipoEntrada, setTipoEntrada] = useState('PROGRAMACAO');
      const [dataExecucao, setDataExecucao] = useState(new Date().toISOString().split('T')[0]);
      const [intervencao, setIntervencao] = useState('');
      
      // Localização com Campo de Busca e Autocomplete
      const [selectedPraca, setSelectedPraca] = useState(null);
      const [searchQuery, setSearchQuery] = useState('');
      const [showSuggestions, setShowSuggestions] = useState(false);
      const [gpsSimulated, setGpsSimulated] = useState(true);

      // Referência para controlar clique fora do autocomplete
      const suggestionsRef = useRef(null);

      // Fechar lista de sugestões ao clicar fora
      useEffect(() => {
        function handleClickOutside(event) {
          if (suggestionsRef.current && !suggestionsRef.current.contains(event.target)) {
            setShowSuggestions(false);
          }
        }
        document.addEventListener("mousedown", handleClickOutside);
        return () => document.removeEventListener("mousedown", handleClickOutside);
      }, []);

      // Sugestão padrão por GPS
      useEffect(() => {
        if (gpsSimulated && !selectedPraca) {
          setSelectedPraca(PRACAS_MOCK[0]); 
          setSearchQuery(PRACAS_MOCK[0].nome);
        }
      }, [gpsSimulated]);

      // 2. Checklist Vistoria
      const [inspectionStatus, setInspectionStatus] = useState({});

      const handleItemStatus = (item, status) => {
        setInspectionStatus(prev => ({
          ...prev,
          [item]: status === "" ? null : status
        }));
      };

      // 3. Equipe de Execução (Ergon + Adicionados Manualmente)
      const [selectedTeam, setSelectedTeam] = useState([]);
      const [customMemberName, setCustomMemberName] = useState('');
      const [customMemberMatricula, setCustomMemberMatricula] = useState('');
      const [showCustomMemberForm, setShowCustomMemberForm] = useState(false);

      const toggleTeamMember = (membro) => {
        const exists = selectedTeam.some(t => t.matricula === membro.matricula);
        if (exists) {
          setSelectedTeam(selectedTeam.filter(t => t.matricula !== membro.matricula));
        } else {
          setSelectedTeam([...selectedTeam, membro]);
        }
      };

      const removeTeamMember = (matricula) => {
        setSelectedTeam(selectedTeam.filter(t => t.matricula !== matricula));
      };

      const handleAddCustomMember = (e) => {
        e.preventDefault();
        if (!customMemberName || !customMemberMatricula) return;
        
        const newMember = {
          matricula: customMemberMatricula,
          nome: customMemberName,
          funcao: 'Gari / Operador Adicional (Manual)',
          isCustom: true
        };

        if (selectedTeam.some(t => t.matricula === customMemberMatricula)) {
          alert("Esta matrícula já está adicionada à equipe.");
          return;
        }

        setSelectedTeam([...selectedTeam, newMember]);
        setCustomMemberName('');
        setCustomMemberMatricula('');
        setShowCustomMemberForm(false);
      };

      // 4. Frota
      const [selectedFrota, setSelectedFrota] = useState([]);
      
      // 5. Linhas dinâmicas de Serviços e Materiais
      const [servicosMateriaisRows, setServicosMateriaisRows] = useState([
        { id: Date.now(), servico: "", qtdServico: 1, item: "", qtdItem: 1, material: "", qtdMaterial: 1 }
      ]);

      const handleAddRow = (index) => {
        const newRow = { id: Date.now() + Math.random(), servico: "", qtdServico: 1, item: "", qtdItem: 1, material: "", qtdMaterial: 1 };
        const updated = [...servicosMateriaisRows];
        updated.splice(index + 1, 0, newRow);
        setServicosMateriaisRows(updated);
      };

      const handleRemoveRow = (id) => {
        if (servicosMateriaisRows.length === 1) {
          setServicosMateriaisRows([{ id: Date.now(), servico: "", qtdServico: 1, item: "", qtdItem: 1, material: "", qtdMaterial: 1 }]);
          return;
        }
        setServicosMateriaisRows(servicosMateriaisRows.filter(r => r.id !== id));
      };

      const handleUpdateRowValue = (id, field, value) => {
        setServicosMateriaisRows(servicosMateriaisRows.map(row => {
          if (row.id === id) {
            return { ...row, [field]: value };
          }
          return row;
        }));
      };
      
      // Evidências, Observações, Assinatura e Envio
      const [photosBefore, setPhotosBefore] = useState([]);
      const [photosAfter, setPhotosAfter] = useState([]);
      const [durationDays, setDurationDays] = useState(1);
      const [observacao, setObservacao] = useState('');
      const [signature, setSignature] = useState(false);
      
      const [isSyncing, setIsSyncing] = useState(false);
      const [syncHistory, setSyncHistory] = useState([]);
      const [showComplianceModal, setShowComplianceModal] = useState(false);

      const handleSubmitService = () => {
        setIsSyncing(true);
        setTimeout(() => {
          const payload = {
            id: 'OS-' + Math.floor(100000 + Math.random() * 900000),
            dataHora: new Date().toLocaleString('pt-BR'),
            vistoriador: {
              tipoEntrada: tipoEntrada,
              dataExecucao: dataExecucao,
              intervencao: intervencao || 'Não Selecionada'
            },
            praca: selectedPraca,
            equipe: selectedTeam,
            frota: selectedFrota,
            vistoriasChecklist: inspectionStatus,
            servicosEMateriais: servicosMateriaisRows,
            duracaoDias: durationDays,
            fotosAntes: photosBefore.length,
            fotosDepois: photosAfter.length,
            observacao: observacao,
            status: 'Sincronizado'
          };

          setSyncHistory([payload, ...syncHistory]);
          setIsSyncing(false);
          setStep(6); // Sucesso Mobile
        }, 1500);
      };

      const resetForm = () => {
        setTipoEntrada('PROGRAMACAO');
        setDataExecucao(new Date().toISOString().split('T')[0]);
        setIntervencao('');
        setSelectedPraca(PRACAS_MOCK[0]);
        setSearchQuery(PRACAS_MOCK[0].nome);
        setSelectedTeam([]);
        setSelectedFrota([]);
        setInspectionStatus({});
        setServicosMateriaisRows([
          { id: Date.now(), servico: "", qtdServico: 1, item: "", qtdItem: 1, material: "", qtdMaterial: 1 }
        ]);
        setPhotosBefore([]);
        setPhotosAfter([]);
        setDurationDays(1);
        setObservacao('');
        setSignature(false);
        setStep(1);
      };

      // Filtro de sugestões para o autocomplete
      const filteredPracas = PRACAS_MOCK.filter(p => 
        p.nome.toLowerCase().includes(searchQuery.toLowerCase()) || 
        p.bairro.toLowerCase().includes(searchQuery.toLowerCase())
      );

      return (
        <div className="min-h-screen bg-slate-900 text-slate-100 font-sans flex flex-col">
          
          {/* --- HEADER PRINCIPAL --- */}
          <header className="bg-slate-950 border-b border-slate-800 px-6 py-4 flex flex-wrap justify-between items-center gap-4 shadow-lg shrink-0">
            <div className="flex items-center space-x-3">
              <div className="bg-orange-600 text-white font-extrabold px-3 py-1.5 rounded text-lg tracking-wider">
                COMLURB
              </div>
              <div>
                <h1 className="text-xl font-bold tracking-tight">App Praça Digital</h1>
                <p className="text-xs text-slate-400">Setor de Parques, Praças e Parcões • Rio de Janeiro</p>
              </div>
            </div>

            {/* SELETOR DE WORKSPACE PRINCIPAL */}
            <div className="bg-slate-900 p-1.5 rounded-2xl border border-slate-800 flex space-x-2">
              <button
                onClick={() => { setWorkspaceTab('split'); resetForm(); }}
                className={`px-5 py-3 rounded-xl text-xs font-black flex items-center gap-2 transition-all ${
                  workspaceTab === 'split' 
                    ? 'bg-orange-600 text-white shadow-lg' 
                    : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/50'
                }`}
              >
                📱 1. Versão Celular + Painel Técnico (Original)
              </button>
              <button
                onClick={() => { setWorkspaceTab('desktop'); resetForm(); }}
                className={`px-5 py-3 rounded-xl text-xs font-black flex items-center gap-2 transition-all ${
                  workspaceTab === 'desktop' 
                    ? 'bg-orange-600 text-white shadow-lg' 
                    : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/50'
                }`}
              >
                💻 2. Versão Tela Cheia de Computador (Mesa)
              </button>
            </div>
            
            <div className="flex items-center gap-3">
              <button 
                onClick={() => setShowComplianceModal(true)} 
                className="bg-slate-800 hover:bg-slate-700 text-xs font-semibold px-4 py-2 rounded-lg border border-slate-700 text-orange-400 transition-all flex items-center gap-2"
              >
                📋 Requisitos do TR
              </button>
              <div className="flex items-center space-x-2 text-xs bg-emerald-950 border border-emerald-800 px-3 py-1.5 rounded-full text-emerald-400">
                <span className="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
                <span>Sistema Ativo</span>
              </div>
            </div>
          </header>

          {/* --- NOTIFICAÇÃO DO MODO ATIVO --- */}
          <div className="bg-slate-950 px-6 py-2 text-xs border-b border-slate-850 flex items-center justify-between">
            <span className="text-slate-400 flex items-center gap-2">
              <span>🖥️ Workspace:</span> 
              <strong className="text-orange-400">{workspaceTab === 'split' ? "Celular + Servidor" : "Tela Cheia Computador"}</strong>
            </span>
            <span className="bg-slate-900 px-2 py-0.5 rounded text-[10px] text-orange-400 font-bold uppercase tracking-wide">
              PROCESSO UNIFICADO
            </span>
          </div>

          {/* ======================================================== */}
          {/* === OPÇÃO 1: SPLIT SCREEN (CELULAR + PAINEL DE DADOS) === */}
          {/* ======================================================== */}
          {workspaceTab === 'split' && (
            <main className="flex-1 grid grid-cols-1 xl:grid-cols-12 gap-6 p-6 overflow-hidden">
              
              {/* LADO ESQUERDO: SMARTPHONE EMULATOR */}
              <section className="xl:col-span-5 flex flex-col items-center justify-start animate-fadeIn">
                <div className="w-full max-w-[420px] h-[740px] bg-slate-950 rounded-[40px] border-[8px] border-slate-800 shadow-2xl overflow-hidden flex flex-col relative">
                  
                  {/* Notch do Celular */}
                  <div className="absolute top-0 inset-x-0 h-6 bg-slate-800 flex justify-center items-center z-50">
                    <div className="w-24 h-4 bg-slate-950 rounded-b-xl"></div>
                  </div>

                  {/* Barra de Status */}
                  <div className="h-10 bg-slate-900 border-b border-slate-800 flex justify-between items-center px-6 pt-5 text-xs text-slate-400 shrink-0">
                    <span>10:12 AM</span>
                    <div className="flex items-center space-x-1.5">
                      <span>📶 4G</span>
                      <span>🔋 85%</span>
                    </div>
                  </div>

                  {/* App Header */}
                  <div className="bg-orange-600 text-white px-4 py-3 shrink-0 flex justify-between items-center shadow-md">
                    <div className="flex items-center space-x-2">
                      <span className="text-xl">📱</span>
                      <div>
                        <h3 className="font-extrabold text-sm tracking-wide">COMLURB - PORTAL ÚNICO</h3>
                        <p className="text-[10px] text-orange-100 font-medium">Vistoria & Execução integrada</p>
                      </div>
                    </div>
                    <span className="text-[10px] bg-black/20 px-2 py-0.5 rounded-full font-bold uppercase tracking-wider text-orange-100">
                      Unificado
                    </span>
                  </div>

                  {/* Progress Wizard */}
                  {step <= 5 && (
                    <div className="bg-slate-900 border-b border-slate-800 px-3 py-2 shrink-0 flex justify-between text-[9px] font-bold text-slate-400">
                      <span className={step === 1 ? "text-orange-400" : "text-emerald-500"}>1. Local</span>
                      <span>➔</span>
                      <span className={step === 2 ? "text-orange-400" : step > 2 ? "text-emerald-500" : ""}>2. Vistoria</span>
                      <span>➔</span>
                      <span className={step === 3 ? "text-orange-400" : step > 3 ? "text-emerald-500" : ""}>3. Equipe</span>
                      <span>➔</span>
                      <span className={step === 4 ? "text-orange-400" : step > 4 ? "text-emerald-500" : ""}>4. Serviços</span>
                      <span>➔</span>
                      <span className={step === 5 ? "text-orange-400" : ""}>5. Fotos</span>
                    </div>
                  )}

                  {/* CORPO DO FORMULÁRIO MOBILE */}
                  <div className="flex-1 overflow-y-auto p-4 bg-slate-900 scrollbar-thin">

                    {/* Etapa 1: Identificação, Localização e Programação */}
                    {step === 1 && (
                      <div className="space-y-4 animate-fadeIn">
                        
                        {/* Campo Tipo de Entrada */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">📋 Tipo de entrada</label>
                          <select 
                            value={tipoEntrada}
                            onChange={(e) => setTipoEntrada(e.target.value)}
                            className="w-full bg-slate-900 border border-slate-700 rounded-lg p-2.5 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                          >
                            <option value="CAS - 1746">CAS - 1746</option>
                            <option value="CAS - OUVIDORIA">CAS - OUVIDORIA</option>
                            <option value="PROCESSO.RIO">PROCESSO.RIO</option>
                            <option value="DIRETORIA">DIRETORIA</option>
                            <option value="PROGRAMACAO">PROGRAMACAO</option>
                            <option value="demanda parlamentar">demanda parlamentar</option>
                          </select>
                        </div>

                        {/* Campo Seleção de Data da Execução */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">📅 Data da execução</label>
                          <input 
                            type="date"
                            value={dataExecucao}
                            onChange={(e) => setDataExecucao(e.target.value)}
                            className="w-full bg-black border border-slate-800 rounded-lg p-2.5 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                          />
                        </div>

                        {/* Localização por Busca Ativa */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner relative" ref={suggestionsRef}>
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">📍 Localização por busca ativa</label>
                          
                          <div className="flex items-center justify-between bg-slate-900 p-2.5 rounded-lg border border-slate-800">
                            <div className="flex items-center space-x-2">
                              <span className="text-xl">📍</span>
                              <div>
                                <p className="text-xs font-bold text-slate-200">Localização Automática</p>
                                <p className="text-[10px] text-emerald-400 font-semibold">Sugerindo praça mais próxima</p>
                              </div>
                            </div>
                            <input type="checkbox" checked={gpsSimulated} onChange={(e) => setGpsSimulated(e.target.checked)} className="w-4 h-4 text-orange-600 bg-slate-700 border-slate-600 rounded focus:ring-orange-500" />
                          </div>

                          <div className="relative">
                            <input 
                              type="text"
                              value={searchQuery}
                              onChange={(e) => {
                                setSearchQuery(e.target.value);
                                setShowSuggestions(true);
                              }}
                              onFocus={() => setShowSuggestions(true)}
                              placeholder="🔍 Digite para buscar a praça..."
                              className="w-full bg-slate-900 border border-slate-700 rounded-lg p-2.5 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                            />

                            {showSuggestions && searchQuery.trim() !== "" && (
                              <ul className="absolute z-50 w-full bg-slate-950 border border-slate-800 rounded-lg mt-1 max-h-40 overflow-y-auto scrollbar-thin text-[11px] divide-y divide-slate-850 shadow-2xl">
                                {filteredPracas.map((praca) => (
                                  <li 
                                    key={praca.cod}
                                    onClick={() => {
                                      setSelectedPraca(praca);
                                      setSearchQuery(praca.nome);
                                      setShowSuggestions(false);
                                    }}
                                    className="p-2 hover:bg-slate-900 cursor-pointer text-slate-200 transition-colors"
                                  >
                                    {praca.nome} - <span className="text-slate-400 font-medium">{praca.bairro}</span>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </div>

                          {/* Retorno Automático Cadastral */}
                          {selectedPraca && (
                            <div className="bg-orange-600/10 border border-orange-500/20 p-3 rounded-lg text-xs space-y-1.5 animate-fadeIn">
                              <p className="font-bold text-orange-400 border-b border-orange-500/20 pb-1">Dados do cadastro:</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">Código:</span> {selectedPraca.cod}</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">Endereço:</span> {selectedPraca.endereco}</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">Bairro:</span> {selectedPraca.bairro}</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">AP:</span> {selectedPraca.ap}</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">UGU:</span> {selectedPraca.ugu}</p>
                              <p className="text-slate-300"><span className="font-semibold text-slate-400">Tipo:</span> {selectedPraca.tipo}</p>
                            </div>
                          )}

                          {/* Campo Intervenções */}
                          {selectedPraca && (
                            <div className="bg-slate-900/80 border border-slate-800 p-3 rounded-lg text-xs space-y-2.5 mt-2 animate-fadeIn">
                              <p className="font-bold text-sky-400">🛠️ Intervenções:</p>
                              <select 
                                value={intervencao}
                                onChange={(e) => setIntervencao(e.target.value)}
                                className="w-full bg-black border border-slate-700 rounded-lg p-2.5 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                              >
                                <option value="" className="text-slate-500">Selecionar intervenção...</option>
                                <option value="CAPINA/ROÇADA">CAPINA/ROÇADA</option>
                                <option value="CONSERVAÇÃO DE JARDINS">CONSERVAÇÃO DE JARDINS</option>
                                <option value="DESOBSTRUÇÃO DE CRAL/RAL">DESOBSTRUÇÃO DE CRAL/RAL</option>
                                <option value="HIGIENIZAÇÃO DE PARCÃO">HIGIENIZAÇÃO DE PARCÃO</option>
                                <option value="LIMPEZA/VARRIÇÃO">LIMPEZA/VARRIÇÃO</option>
                                <option value="MANUTENÇÃO DE BRINQUEDOS">MANUTENÇÃO DE BRINQUEDOS</option>
                                <option value="MANUTENÇÃO DE MOBILIÁRIO">MANUTENÇÃO DE MOBILIÁRIO</option>
                                <option value="MANUTENÇÃO DE QUADRA">MANUTENÇÃO DE QUADRA</option>
                                <option value="MANUTENÇÃO DE CERCAS/PORTÕES">MANUTENÇÃO DE CERCAS/PORTÕES</option>
                                <option value="PODA DE ÁRVORE">PODA DE ÁRVORE</option>
                                <option value="REMOÇÃO DE RESÍDUOS">REMOÇÃO DE RESÍDUOS</option>
                                <option value="OUTROS">OUTROS</option>
                              </select>
                            </div>
                          )}
                        </div>

                      </div>
                    )}

                    {/* Etapa 2: Checklist Vistoria */}
                    {step === 2 && (
                      <div className="space-y-4 animate-fadeIn">
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3 shadow-inner">
                          <h4 className="text-xs font-bold text-slate-200 uppercase tracking-wide mb-1">🔍 Diagnóstico de Danos (Vistoria)</h4>
                          <p className="text-[10px] text-slate-400 mb-3">Selecione o estado ao lado de cada palavra:</p>

                          <div className="space-y-2 max-h-[460px] overflow-y-auto pr-1">
                            {ITENS_PRACA_MOCK.map((categoria) => (
                              <div key={categoria.id} className="border-t border-slate-800 pt-2.5 first:border-0 first:pt-0">
                                <p className="text-[10px] font-bold text-orange-400 mb-1.5 uppercase">{categoria.categoria}</p>
                                <div className="space-y-1.5">
                                  {categoria.itens.map((item, idx) => {
                                    const key = `${item.nome} - ${item.subItem}`;
                                    const currentStatus = inspectionStatus[key];
                                    return (
                                      <div key={idx} className="bg-slate-900 py-1.5 px-2.5 rounded-lg border border-slate-800/60 flex items-center justify-between gap-2 text-xs">
                                        <div className="flex flex-col text-left max-w-[55%]">
                                          <span className="font-extrabold text-[9px] text-slate-400 uppercase tracking-wider">{item.nome}</span>
                                          <span className="text-slate-200 font-bold text-[11px] leading-tight truncate">{item.subItem}</span>
                                        </div>
                                        <select
                                          value={currentStatus || ''}
                                          onChange={(e) => handleItemStatus(key, e.target.value)}
                                          className="bg-black border border-slate-800 text-slate-200 py-1 px-1.5 rounded text-[11px] font-bold focus:ring-1 focus:ring-orange-500 max-w-[45%] h-8"
                                        >
                                          <option value="">Selecionar...</option>
                                          {item.options.map(opt => (
                                            <option key={opt} value={opt} className="bg-black text-slate-200">{opt}</option>
                                          ))}
                                        </select>
                                      </div>
                                    );
                                  })}
                                </div>
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    )}

                    {/* Etapa 3: Equipe Ergon e Frota Hilux */}
                    {step === 3 && (
                      <div className="space-y-4 animate-fadeIn">
                        
                        {/* Equipe do Ergon */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner">
                          <div className="flex justify-between items-center">
                            <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">👥 Equipe do Dia (Ergon)</label>
                            <button 
                              onClick={() => setShowCustomMemberForm(!showCustomMemberForm)}
                              className="text-[11px] bg-slate-800 text-orange-400 px-2 py-1 rounded border border-slate-750 font-bold"
                            >
                              {showCustomMemberForm ? "Fechar ✕" : "➕ Novo Gari"}
                            </button>
                          </div>

                          {showCustomMemberForm && (
                            <form onSubmit={handleAddCustomMember} className="bg-slate-900 p-3 rounded-lg border border-orange-500/30 space-y-2 animate-fadeIn">
                              <p className="text-[10px] text-orange-400 font-bold">Adicionar Funcionário fora da Lista:</p>
                              <input 
                                type="text" 
                                placeholder="Nome Completo" 
                                value={customMemberName} 
                                onChange={(e) => setCustomMemberName(e.target.value)}
                                className="w-full bg-slate-950 border border-slate-750 rounded p-1.5 text-xs text-slate-200"
                                required
                              />
                              <input 
                                type="text" 
                                placeholder="Matrícula" 
                                value={customMemberMatricula} 
                                onChange={(e) => setCustomMemberMatricula(e.target.value)}
                                className="w-full bg-slate-950 border border-slate-750 rounded p-1.5 text-xs text-slate-200"
                                required
                              />
                              <button type="submit" className="w-full bg-orange-600 text-white text-xs font-bold py-1.5 rounded">Adicionar ➕</button>
                            </form>
                          )}

                          <div className="space-y-1.5 max-h-44 overflow-y-auto pr-1">
                            {EQUIPE_ERGON_MOCK.map((membro) => {
                              const isSelected = selectedTeam.some(t => t.matricula === membro.matricula);
                              return (
                                <div key={membro.matricula} className="flex gap-1.5">
                                  <button 
                                    onClick={() => toggleTeamMember(membro)} 
                                    className={`flex-1 text-left p-2 rounded-lg text-xs flex items-center justify-between border ${isSelected ? 'bg-sky-500/10 border-sky-500 text-sky-300 font-bold' : 'bg-slate-900 border-slate-800 text-slate-300'}`}
                                  >
                                    <div>
                                      <p>{membro.nome}</p>
                                      <p className="text-[9px] text-slate-400">Matr: {membro.matricula}</p>
                                    </div>
                                    <span>{isSelected ? '✅' : '➕'}</span>
                                  </button>
                                  {isSelected && (
                                    <button onClick={() => removeTeamMember(membro.matricula)} className="bg-red-900/40 hover:bg-red-900 text-red-400 p-2 rounded-lg border border-red-500/30 flex items-center justify-center w-10 shrink-0">🗑️</button>
                                  )}
                                </div>
                              );
                            })}

                            {selectedTeam.filter(t => t.isCustom).map((custom) => (
                              <div key={custom.matricula} className="flex gap-1.5">
                                <div className="flex-1 text-left p-2 rounded-lg text-xs flex items-center justify-between border bg-orange-500/10 border-orange-500 text-orange-300 font-bold">
                                  <div>
                                    <p>{custom.nome} <span className="bg-orange-600 text-white text-[8px] px-1 rounded">manual</span></p>
                                    <p className="text-[9px] text-slate-400">Matr: {custom.matricula}</p>
                                  </div>
                                  <span>✅</span>
                                </div>
                                <button onClick={() => removeTeamMember(custom.matricula)} className="bg-red-900/40 hover:bg-red-900 text-red-400 p-2 rounded-lg border border-red-500/30 w-10 shrink-0 flex items-center justify-center">🗑️</button>
                              </div>
                            ))}
                          </div>
                        </div>

                        {/* Veículos e Frota */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">🚚 VEÍCULOS E FROTA</label>
                          <select 
                            className="w-full bg-slate-900 border border-slate-750 rounded-lg p-2.5 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                            value={selectedFrota[0]?.prefixo || ''}
                            onChange={(e) => {
                              const selected = FROTA_MOCK.find(f => f.prefixo === e.target.value);
                              setSelectedFrota(selected ? [selected] : []);
                            }}
                          >
                            <option value="">Selecione o prefixo do veículo...</option>
                            {FROTA_MOCK.map((veiculo) => (
                              <option key={veiculo.prefixo} value={veiculo.prefixo}>{veiculo.prefixo} - {veiculo.modelo}</option>
                            ))}
                          </select>
                        </div>

                      </div>
                    )}

                    {/* Etapa 4: Serviços e Materiais Dinâmicos */}
                    {step === 4 && (
                      <div className="space-y-4 animate-fadeIn">
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 shadow-inner">
                          <h4 className="text-xs font-bold text-slate-200 uppercase tracking-wide mb-1">🛠️ Serviços e Materiais</h4>
                          <p className="text-[10px] text-slate-400 mb-3">Preencha as linhas dinâmicas de serviços e materiais gastas nesta OS:</p>

                          <div className="space-y-4 max-h-[440px] overflow-y-auto pr-1">
                            {servicosMateriaisRows.map((row, index) => (
                              <div key={row.id} className="bg-slate-900 p-3 rounded-xl border border-slate-800 space-y-3 relative">
                                <div className="flex justify-between items-center border-b border-slate-855 pb-1">
                                  <span className="text-[10px] font-bold text-orange-400 uppercase">Linha {index + 1}</span>
                                  <button onClick={() => handleRemoveRow(row.id)} className="text-red-400 hover:text-red-300 text-xs flex items-center gap-1 bg-red-950/20 px-2 py-1 rounded border border-red-900/30">🗑️</button>
                                </div>

                                {/* Serviço */}
                                <div className="grid grid-cols-3 gap-2">
                                  <div className="col-span-2">
                                    <label className="block text-[9px] text-slate-400">Serviço:</label>
                                    <select value={row.servico} onChange={(e) => handleUpdateRowValue(row.id, 'servico', e.target.value)} className="w-full bg-black border border-slate-850 p-1.5 rounded text-[11px] text-slate-100">
                                      <option value="">Selecione...</option>
                                      {SERVICOS_LIST.map(s => <option key={s} value={s}>{s}</option>)}
                                    </select>
                                  </div>
                                  <div>
                                    <label className="block text-[9px] text-slate-400">Qtd:</label>
                                    <input type="number" min="1" value={row.qtdServico} onChange={(e) => handleUpdateRowValue(row.id, 'qtdServico', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-850 p-1 rounded text-[11px] text-center" />
                                  </div>
                                </div>

                                {/* Item */}
                                <div className="grid grid-cols-3 gap-2">
                                  <div className="col-span-2">
                                    <label className="block text-[9px] text-slate-400">Item:</label>
                                    <select value={row.item} onChange={(e) => handleUpdateRowValue(row.id, 'item', e.target.value)} className="w-full bg-black border border-slate-850 p-1 rounded text-[11px] text-slate-100">
                                      <option value="">Selecione...</option>
                                      {ITENS_LIST.map(i => <option key={i} value={i}>{i}</option>)}
                                    </select>
                                  </div>
                                  <div>
                                    <label className="block text-[9px] text-slate-400">Qtd:</label>
                                    <input type="number" min="1" value={row.qtdItem} onChange={(e) => handleUpdateRowValue(row.id, 'qtdItem', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-850 p-1 rounded text-[11px] text-center" />
                                  </div>
                                </div>

                                {/* Material */}
                                <div className="grid grid-cols-3 gap-2">
                                  <div className="col-span-2">
                                    <label className="block text-[9px] text-slate-400">Material:</label>
                                    <select value={row.material} onChange={(e) => handleUpdateRowValue(row.id, 'material', e.target.value)} className="w-full bg-black border border-slate-850 p-1 rounded text-[11px] text-slate-100">
                                      <option value="">Selecione...</option>
                                      {MATERIAIS_LIST.map(m => <option key={m} value={m}>{m}</option>)}
                                    </select>
                                  </div>
                                  <div>
                                    <label className="block text-[9px] text-slate-400">Qtd:</label>
                                    <input type="number" min="1" value={row.qtdMaterial} onChange={(e) => handleUpdateRowValue(row.id, 'qtdMaterial', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-850 p-1 rounded text-[11px] text-center" />
                                  </div>
                                </div>

                                <div className="flex justify-end pt-1">
                                  <button type="button" onClick={() => handleAddRow(index)} className="text-[11px] text-sky-400 font-bold bg-sky-950/40 px-2.5 py-1.5 rounded border border-sky-900/30">➕ Incluir Linha</button>
                                </div>
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    )}

                    {/* Etapa 5: Evidências e Fechamento */}
                    {step === 5 && (
                      <div className="space-y-4 animate-fadeIn">
                        
                        {/* Fotos */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-3 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">📸 Registro Fotográfico do Serviço</label>
                          <div className="grid grid-cols-2 gap-3">
                            <div className="bg-slate-900 p-2.5 rounded-lg border border-slate-800 flex flex-col items-center">
                              <p className="text-[10px] font-bold text-red-400 mb-1">ANTES</p>
                              <button onClick={() => addMockPhoto('antes')} className="w-full bg-slate-850 text-[10px] p-2 rounded border border-dashed border-red-500/30 text-slate-300 font-bold">📸 Tirar Antes</button>
                              <div className="flex flex-wrap gap-1 mt-2">
                                {photosBefore.map(p => <img key={p.id} src={p.url} className="w-8 h-8 object-cover rounded border border-slate-700" />)}
                              </div>
                            </div>
                            <div className="bg-slate-900 p-2.5 rounded-lg border border-slate-800 flex flex-col items-center">
                              <p className="text-[10px] font-bold text-emerald-400 mb-1">DEPOIS</p>
                              <button onClick={() => addMockPhoto('depois')} className="w-full bg-slate-850 text-[10px] p-2 rounded border border-dashed border-emerald-500/30 text-slate-300 font-bold">📸 Tirar Depois</button>
                              <div className="flex flex-wrap gap-1 mt-2">
                                {photosAfter.map(p => <img key={p.id} src={p.url} className="w-8 h-8 object-cover rounded border border-slate-700" />)}
                              </div>
                            </div>
                          </div>
                        </div>

                        {/* Duração em Dias */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-2 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">⏱️ Dias de Manutenção (Duração)</label>
                          <div className="flex items-center justify-between bg-slate-900 p-2 rounded-lg border border-slate-800">
                            <span className="text-xs text-slate-300">Dias da equipe na praça:</span>
                            <div className="flex items-center space-x-3">
                              <button onClick={() => setDurationDays(Math.max(1, durationDays - 1))} className="w-8 h-8 bg-slate-800 rounded-full flex items-center justify-center font-bold">-</button>
                              <span className="text-sm font-bold text-orange-400">{durationDays}</span>
                              <button onClick={() => setDurationDays(durationDays + 1)} className="w-8 h-8 bg-slate-800 rounded-full flex items-center justify-center font-bold">+</button>
                            </div>
                          </div>
                        </div>

                        {/* Notas */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-2 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">📝 Notas da Execução</label>
                          <textarea value={observacao} onChange={(e) => setObservacao(e.target.value)} placeholder="Detalhes adicionais do serviço..." className="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-xs h-16 resize-none" />
                        </div>

                        {/* Assinatura */}
                        <div className="bg-slate-950 border border-slate-800 rounded-xl p-3.5 space-y-2 shadow-inner">
                          <label className="block text-xs font-bold text-slate-300 uppercase tracking-wide">✍️ Assinatura Encarregado</label>
                          <div className="border border-slate-700 bg-slate-900 rounded-lg h-20 relative flex flex-col items-center justify-center">
                            {signature ? (
                              <div className="text-center animate-fadeIn">
                                <p className="text-xs font-bold italic">Carlos Alberto Silva</p>
                                <p className="text-[9px] text-slate-500 font-medium">Assinado Digitalmente</p>
                              </div>
                            ) : (
                              <button onClick={() => setSignature(true)} className="text-xs text-slate-400 hover:text-orange-400">👇 Clique para Assinar</button>
                            )}
                          </div>
                        </div>

                      </div>
                    )}

                    {/* SUCESSO */}
                    {step === 6 && (
                      <div className="py-8 text-center space-y-4 animate-scaleUp">
                        <div className="w-16 h-16 bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded-full flex items-center justify-center text-3xl mx-auto flex items-center justify-center shadow-lg shadow-emerald-950">✓</div>
                        <div>
                          <h3 className="text-lg font-bold">Relatório e O.S. Enviados!</h3>
                          <p className="text-xs text-emerald-400 mt-1">Sincronizado na nuvem da Comlurb</p>
                        </div>
                        <button onClick={resetForm} className="bg-orange-600 hover:bg-orange-500 text-white font-bold text-xs py-2.5 px-6 rounded-lg uppercase">Iniciar Nova OS</button>
                      </div>
                    )}

                  </div>

                  {/* NAVEGAÇÃO MOBILE */}
                  {step <= 5 && (
                    <div className="bg-slate-950 border-t border-slate-800 p-3 shrink-0 flex justify-between gap-3">
                      {step > 1 ? (
                        <button onClick={() => setStep(step - 1)} className="flex-1 bg-slate-900 hover:bg-slate-850 text-slate-300 font-bold py-2.5 rounded-xl border border-slate-800 text-xs text-center">◀ Voltar</button>
                      ) : <div className="flex-1"></div>}
                      
                      {step < 5 ? (
                        <button onClick={() => setStep(step + 1)} className="flex-1 bg-orange-600 hover:bg-orange-500 text-white font-bold py-2.5 rounded-xl text-xs text-center">Avançar ▶</button>
                      ) : (
                        <button onClick={handleSubmitService} disabled={isSyncing} className="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 rounded-xl text-xs text-center">
                          {isSyncing ? 'Enviando...' : 'Finalizar e Enviar 📦'}
                        </button>
                      )}
                    </div>
                  )}

                  <div className="h-4 bg-slate-950 shrink-0 flex justify-center items-center pb-1">
                    <div className="w-28 h-1 bg-slate-700 rounded-full"></div>
                  </div>

                </div>
              </section>

              {/* LADO DIREITO: DASHBOARD INTEGRADO DE DADOS PAYLOAD */}
              <section className="xl:col-span-7 flex flex-col gap-6 animate-fadeIn">
                <div className="bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-lg flex items-center justify-between">
                  <div className="space-y-1">
                    <p className="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Status do Simulador Unificado</p>
                    <div className="flex items-center gap-2">
                      <span className="w-3 h-3 rounded-full bg-emerald-500 animate-pulse"></span>
                      <span className="text-sm font-black text-slate-200">Preenchimento Móvel Integrado</span>
                    </div>
                  </div>
                </div>

                <div className="bg-slate-950 border border-slate-800 rounded-xl p-4 flex-1 flex flex-col min-h-[400px] shadow-lg">
                  <div className="flex justify-between items-center mb-3">
                    <h3 className="text-xs font-bold text-slate-200 uppercase tracking-wider flex items-center gap-2">
                      📂 Dados Estruturados Recebidos na Central (JSON)
                    </h3>
                    <span className="text-[10px] bg-slate-800 text-slate-400 px-2 py-0.5 rounded font-mono">POST /api/v1/manutencao</span>
                  </div>
                  
                  <div className="bg-slate-900 rounded-lg p-3.5 font-mono text-[11px] text-emerald-400 flex-1 overflow-auto max-h-[420px] border border-slate-800 scrollbar-thin">
                    <pre className="whitespace-pre-wrap">
{JSON.stringify({
  modo: "MÓVEL UNIFICADO (VISTORIA + O.S.)",
  timestamp: new Date().toISOString(),
  responsavel_vistoria: {
    tipo_entrada: tipoEntrada,
    data_execucao: dataExecucao,
    intervencao: intervencao || 'Não Selecionada'
  },
  localizacao_praca: selectedPraca ? { id: selectedPraca.id, nome: selectedPraca.nome, bairro: selectedPraca.bairro, lat: selectedPraca.lat, lng: selectedPraca.lng } : null,
  vistoria_checklist_anexo_ii: inspectionStatus,
  equipe_manutencao_ergon: selectedTeam.map(t => ({ nome: t.nome, matricula: t.matricula, cargo: t.funcao, manual: t.isCustom || false })),
  frota_veiculos: selectedFrota.map(f => ({ placa: f.placa, modelo: f.modelo, prefixo: f.prefixo })),
  servicos_e_materiais_aplicados: servicosMateriaisRows.map((r, i) => ({
    linha: i + 1,
    servico: r.servico || "Não preenchido",
    quantidade_servico: r.qtdServico,
    item: r.item || "Não preenchido",
    quantidade_item: r.qtdItem,
    material: r.material || "Não preenchido",
    quantidade_material: r.qtdMaterial
  })),
  duracao_dias: durationDays,
  evidencias: { fotos_antes: photosBefore.length, fotos_depois: photosAfter.length },
  assinatura_comprovada: signature
}, null, 2)}
                    </pre>
                  </div>
                </div>
              </section>

            </main>
          )}

          {/* ============================================== */}
          {/* === OPÇÃO 2: TELA CHEIA (DIGITAÇÃO DE MESA) === */}
          {/* ============================================== */}
          {workspaceTab === 'desktop' && (
            <main className="flex-1 p-6 space-y-6 overflow-y-auto animate-fadeIn scrollbar-thin">
              
              {/* Alerta Administrativo */}
              <div className="bg-slate-950 border border-slate-800 rounded-xl p-4 flex flex-wrap justify-between items-center gap-4 shadow-md">
                <div className="flex items-center space-x-3">
                  <span className="text-2xl">💻</span>
                  <div>
                    <h2 className="text-sm font-bold text-slate-200">Terminal de Lançamento Unificado (Mesa da Gerência)</h2>
                    <p className="text-xs text-slate-400">Preencha o diagnóstico de vistoria e a execução de Ordem de Serviço na mesma tela.</p>
                  </div>
                </div>
                <div className="text-right">
                  <span className="bg-slate-850 text-orange-400 text-xs font-black px-4 py-2 rounded-xl border border-slate-800">
                    Supervisor de Mesa: Carlos Alberto (Mesa)
                  </span>
                </div>
              </div>

              {step <= 5 ? (
                <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
                  
                  {/* COLUNA ESQUERDA - IDENTIFICAÇÃO, LOCALIZAÇÃO, EQUIPE & FROTA */}
                  <div className="lg:col-span-4 space-y-6">
                    
                    {/* Seção 1: Identificação do Local e Vistoriador */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-5 space-y-4 shadow-xl relative" ref={suggestionsRef}>
                      <h3 className="text-xs font-bold text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2">
                        <span>📍</span> IDENTIFICAÇÃO E LOCAL
                      </h3>

                      {/* Campos Tipo de Entrada e Data de Execução */}
                      <div className="space-y-2 bg-slate-900/50 p-3 rounded-lg border border-slate-800">
                        <p className="text-[10px] font-bold text-orange-400 uppercase tracking-wider">Tipo de entrada:</p>
                        <select 
                          value={tipoEntrada}
                          onChange={(e) => setTipoEntrada(e.target.value)}
                          className="w-full bg-slate-950 border border-slate-700 rounded p-2 text-xs text-slate-100 font-bold mb-2"
                        >
                          <option value="CAS - 1746">CAS - 1746</option>
                          <option value="CAS - OUVIDORIA">CAS - OUVIDORIA</option>
                          <option value="PROCESSO.RIO">PROCESSO.RIO</option>
                          <option value="DIRETORIA">DIRETORIA</option>
                          <option value="PROGRAMACAO">PROGRAMACAO</option>
                          <option value="demanda parlamentar">demanda parlamentar</option>
                        </select>

                        {/* Campo Data de Execução */}
                        <p className="text-[10px] font-bold text-orange-400 uppercase tracking-wider">Data da execução:</p>
                        <input 
                          type="date"
                          value={dataExecucao}
                          onChange={(e) => setDataExecucao(e.target.value)}
                          className="w-full bg-black border border-slate-700 rounded p-2 text-xs text-slate-100 font-bold"
                        />
                      </div>

                      {/* Autocomplete de Praças */}
                      <div className="space-y-2 relative">
                        <label className="block text-xs font-semibold text-slate-400">Buscar Praça ou Parque (Busca Ativa):</label>
                        <input 
                          type="text"
                          value={searchQuery}
                          onChange={(e) => {
                            setSearchQuery(e.target.value);
                            setShowSuggestions(true);
                          }}
                          onFocus={() => setShowSuggestions(true)}
                          placeholder="🔍 Comece a digitar o nome da praça..."
                          className="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-xs text-slate-100 font-bold focus:ring-1 focus:ring-orange-500"
                        />

                        {showSuggestions && searchQuery.trim() !== "" && (
                          <ul className="absolute z-50 w-full bg-slate-950 border border-slate-800 rounded-lg mt-1 max-h-48 overflow-y-auto scrollbar-thin text-xs divide-y divide-slate-850 shadow-2xl">
                            {filteredPracas.map((praca) => (
                              <li 
                                key={praca.cod}
                                onClick={() => {
                                  setSelectedPraca(praca);
                                  setSearchQuery(praca.nome);
                                  setShowSuggestions(false);
                                }}
                                className="p-2.5 hover:bg-slate-900 cursor-pointer text-slate-200 transition-colors"
                              >
                                {praca.nome} - <span className="text-slate-400 font-medium">{praca.bairro}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                      </div>

                      {/* Dados do cadastro */}
                      {selectedPraca && (
                        <div className="bg-orange-600/10 border border-orange-500/20 p-4 rounded-xl text-xs space-y-2.5 animate-fadeIn">
                          <p className="font-bold text-orange-400 border-b border-orange-500/20 pb-1 flex items-center gap-1">
                            <span>📋</span> Dados do cadastro:
                          </p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">Código:</span> {selectedPraca.cod}</p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">Endereço:</span> {selectedPraca.endereco}</p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">Bairro:</span> {selectedPraca.bairro}</p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">AP:</span> {selectedPraca.ap}</p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">UGU:</span> {selectedPraca.ugu}</p>
                          <p className="text-slate-300"><span className="font-semibold text-slate-400">Tipo:</span> {selectedPraca.tipo}</p>
                        </div>
                      )}

                      {/* Campo Intervenções */}
                      {selectedPraca && (
                        <div className="bg-slate-900/50 border border-slate-800 p-4 rounded-xl text-xs space-y-3 mt-2 animate-fadeIn">
                          <p className="font-bold text-sky-400 flex items-center gap-1">
                            <span>🛠️</span> Intervenções:
                          </p>
                          <select 
                            value={intervencao}
                            onChange={(e) => setIntervencao(e.target.value)}
                            className="w-full bg-black border border-slate-700 rounded-lg p-2.5 text-xs text-slate-100 font-bold"
                          >
                            <option value="" className="text-slate-500">Selecionar intervenção...</option>
                            <option value="CAPINA/ROÇADA">CAPINA/ROÇADA</option>
                            <option value="CONSERVAÇÃO DE JARDINS">CONSERVAÇÃO DE JARDINS</option>
                            <option value="DESOBSTRUÇÃO DE CRAL/RAL">DESOBSTRUÇÃO DE CRAL/RAL</option>
                            <option value="HIGIENIZAÇÃO DE PARCÃO">HIGIENIZAÇÃO DE PARCÃO</option>
                            <option value="LIMPEZA/VARRIÇÃO">LIMPEZA/VARRIÇÃO</option>
                            <option value="MANUTENÇÃO DE BRINQUEDOS">MANUTENÇÃO DE BRINQUEDOS</option>
                            <option value="MANUTENÇÃO DE MOBILIÁRIO">MANUTENÇÃO DE MOBILIÁRIO</option>
                            <option value="MANUTENÇÃO DE QUADRA">MANUTENÇÃO DE QUADRA</option>
                            <option value="MANUTENÇÃO DE CERCAS/PORTÕES">MANUTENÇÃO DE CERCAS/PORTÕES</option>
                            <option value="PODA DE ÁRVORE">PODA DE ÁRVORE</option>
                            <option value="REMOÇÃO DE RESÍDUOS">REMOÇÃO DE RESÍDUOS</option>
                            <option value="OUTROS">OUTROS</option>
                          </select>
                        </div>
                      )}
                    </div>

                    {/* Seção 2: Equipe de Trabalho */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-5 space-y-4 shadow-xl">
                      <div className="flex justify-between items-center border-b border-slate-800 pb-2">
                        <h3 className="text-xs font-bold text-slate-300 uppercase tracking-widest flex items-center gap-2">
                          <span>👥</span> EQUIPE DE EXECUÇÃO
                        </h3>
                        <button 
                          onClick={() => setShowCustomMemberForm(!showCustomMemberForm)}
                          className="bg-slate-900 text-orange-400 text-xs px-2.5 py-1 rounded border border-slate-750 font-bold hover:bg-slate-850"
                        >
                          {showCustomMemberForm ? "Fechar ✕" : "➕ Adicionar Fora da Lista"}
                        </button>
                      </div>

                      {showCustomMemberForm && (
                        <form onSubmit={handleAddCustomMember} className="bg-slate-900 p-3.5 rounded-xl border border-orange-500/30 space-y-3 animate-fadeIn">
                          <p className="text-xs font-bold text-orange-400">➕ Cadastrar Funcionário:</p>
                          <div className="grid grid-cols-2 gap-2">
                            <input type="text" placeholder="Nome Completo" value={customMemberName} onChange={(e) => setCustomMemberName(e.target.value)} className="bg-slate-950 border border-slate-750 rounded p-2 text-xs text-slate-100" required />
                            <input type="text" placeholder="Matrícula" value={customMemberMatricula} onChange={(e) => setCustomMemberMatricula(e.target.value)} className="bg-slate-950 border border-slate-750 rounded p-2 text-xs text-slate-100" required />
                          </div>
                          <button type="submit" className="w-full bg-orange-600 text-white text-xs font-bold py-2 rounded-lg">Confirmar Entrada na Equipe</button>
                        </form>
                      )}

                      <div className="space-y-2 max-h-48 overflow-y-auto pr-1 scrollbar-thin">
                        {EQUIPE_ERGON_MOCK.map((membro) => {
                          const isSelected = selectedTeam.some(t => t.matricula === membro.matricula);
                          return (
                            <div key={membro.matricula} className={`p-2.5 rounded-xl border flex justify-between items-center transition-all ${isSelected ? 'bg-sky-500/10 border-sky-500 text-sky-400 font-bold' : 'bg-slate-900 border-slate-855 text-slate-300 hover:bg-slate-800'}`}>
                              <div onClick={() => toggleTeamMember(membro)} className="flex-1 cursor-pointer">
                                <p className="text-xs font-bold">{membro.nome}</p>
                                <p className="text-[10px] text-slate-400">{membro.funcao} • Matrícula: {membro.matricula}</p>
                              </div>
                              <div className="flex items-center space-x-2">
                                <input type="checkbox" checked={isSelected} onChange={() => toggleTeamMember(membro)} className="rounded text-sky-600 focus:ring-sky-500" />
                                {isSelected && (
                                  <button onClick={() => removeTeamMember(membro.matricula)} className="text-red-400 hover:text-red-300 text-sm p-1">🗑️</button>
                                )}
                              </div>
                            </div>
                          );
                        })}

                        {selectedTeam.filter(t => t.isCustom).map((custom) => (
                          <div key={custom.matricula} className="p-3 rounded-xl border bg-orange-500/10 border-orange-500 text-orange-400 font-bold flex justify-between items-center">
                            <div>
                              <p className="text-xs">{custom.nome} <span className="bg-orange-600 text-white text-[8px] px-1 rounded">manual</span></p>
                              <p className="text-[10px] text-slate-400">Matrícula: {custom.matricula}</p>
                            </div>
                            <button onClick={() => removeTeamMember(custom.matricula)} className="text-red-400 hover:text-red-300 text-sm p-1">🗑️</button>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* Seção 3: Veículos e Frota */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-5 space-y-4 shadow-xl">
                      <h3 className="text-xs font-bold text-slate-300 uppercase tracking-wider border-b border-slate-800 pb-2 flex items-center gap-2">
                        <span>🚚</span> VEÍCULOS E FROTA
                      </h3>
                      <div className="space-y-3">
                        <select 
                          className="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-sm text-slate-100 font-bold focus:ring-1"
                          value={selectedFrota[0]?.prefixo || ''}
                          onChange={(e) => {
                            const selected = FROTA_MOCK.find(f => f.prefixo === e.target.value);
                            setSelectedFrota(selected ? [selected] : []);
                          }}
                        >
                          <option value="">Selecione o prefixo do veículo...</option>
                          {FROTA_MOCK.map((veiculo) => (
                            <option key={veiculo.prefixo} value={veiculo.prefixo}>{veiculo.prefixo} - {veiculo.modelo}</option>
                          ))}
                        </select>
                      </div>
                    </div>

                  </div>

                  {/* COLUNA DIREITA - CHECKLIST DA VISTORIA OU SERVIÇOS E MATERIAIS */}
                  <div className="lg:col-span-8 space-y-6">
                    
                    {/* Checklist Vistoria */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-6 shadow-xl space-y-4 animate-fadeIn">
                      <h3 className="text-sm font-extrabold text-orange-400 uppercase tracking-wider flex items-center gap-2 border-b border-slate-800 pb-3">
                        <span>🕵️</span> 1. DIAGNÓSTICO DE VISTORIA (ITENS MAPEADOS DO CADERNO)
                      </h3>

                      <div className="grid grid-cols-1 gap-4">
                        {ITENS_PRACA_MOCK.map((categoria) => (
                          <div key={categoria.id} className="bg-slate-900/40 p-4 rounded-xl border border-slate-850 space-y-3">
                            <p className="text-xs font-black text-slate-200 uppercase bg-slate-900 px-2.5 py-2 rounded">{categoria.categoria}</p>
                            <div className="space-y-2">
                              {categoria.itens.map((item, idx) => {
                                const key = `${item.nome} - ${item.subItem}`;
                                const currentStatus = inspectionStatus[key];
                                return (
                                  <div key={idx} className="flex flex-col xl:flex-row xl:items-center justify-between p-3 rounded-xl bg-slate-950/60 border border-slate-900 gap-3">
                                    <div className="flex flex-col sm:flex-row sm:items-center gap-1.5 sm:gap-6 text-left">
                                      <span className="text-xs font-black text-slate-400 uppercase tracking-wider min-w-[140px] border-r border-slate-850 pr-4">{item.nome}</span>
                                      <span className="text-xs font-bold text-slate-200">{item.subItem}</span>
                                    </div>
                                    <select
                                      value={currentStatus || ''}
                                      onChange={(e) => handleItemStatus(key, e.target.value)}
                                      className="bg-black border border-slate-800 text-slate-200 py-1 px-2 rounded-lg text-xs font-black focus:ring-1 max-w-[200px] h-8"
                                    >
                                      <option value="">Selecionar...</option>
                                      {item.options.map(opt => (
                                        <option key={opt} value={opt}>{opt}</option>
                                      ))}
                                    </select>
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* Serviços e Materiais Dinâmicos */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-5 space-y-4 shadow-xl">
                      <div className="flex justify-between items-center border-b border-slate-800 pb-2">
                        <h3 className="text-sm font-extrabold text-orange-400 uppercase tracking-wider">
                          🛠️ 2. REGISTRO DE SERVIÇOS E MATERIAIS EXECUTADOS
                        </h3>
                      </div>

                      <div className="hidden xl:grid grid-cols-12 gap-2 text-[10px] font-black text-slate-400 border-b border-slate-800 pb-1.5 px-1">
                        <div className="col-span-2">1. SERVIÇO</div>
                        <div className="col-span-1 text-center">QTD</div>
                        <div className="col-span-3">2. ITEM</div>
                        <div className="col-span-1 text-center">QTD</div>
                        <div className="col-span-3">3. MATERIAL</div>
                        <div className="col-span-1 text-center">QTD</div>
                        <div className="col-span-1 text-center">AÇÃO</div>
                      </div>

                      <div className="space-y-3 max-h-[380px] overflow-y-auto pr-2 scrollbar-thin">
                        {servicosMateriaisRows.map((row, index) => (
                          <div key={row.id} className="space-y-2.5 xl:space-y-0">
                            <div className="grid grid-cols-1 xl:grid-cols-12 gap-2 items-center">
                              
                              <div className="col-span-1 xl:col-span-2">
                                <select value={row.servico} onChange={(e) => handleUpdateRowValue(row.id, 'servico', e.target.value)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-slate-100 h-9 font-bold">
                                  <option value="">Selecione...</option>
                                  {SERVICOS_LIST.map(s => <option key={s} value={s}>{s}</option>)}
                                </select>
                              </div>

                              <div className="col-span-1 xl:col-span-1">
                                <input type="number" min="1" value={row.qtdServico} onChange={(e) => handleUpdateRowValue(row.id, 'qtdServico', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-center text-orange-400 font-bold h-9" />
                              </div>

                              <div className="col-span-1 xl:col-span-3">
                                <select value={row.item} onChange={(e) => handleUpdateRowValue(row.id, 'item', e.target.value)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-slate-100 h-9 font-bold">
                                  <option value="">Selecione...</option>
                                  {ITENS_LIST.map(i => <option key={i} value={i}>{i}</option>)}
                                </select>
                              </div>

                              <div className="col-span-1 xl:col-span-1">
                                <input type="number" min="1" value={row.qtdItem} onChange={(e) => handleUpdateRowValue(row.id, 'qtdItem', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-center text-orange-400 font-bold h-9" />
                              </div>

                              <div className="col-span-1 xl:col-span-3">
                                <select value={row.material} onChange={(e) => handleUpdateRowValue(row.id, 'material', e.target.value)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-slate-100 h-9 font-bold">
                                  <option value="">Selecione...</option>
                                  {MATERIAIS_LIST.map(m => <option key={m} value={m}>{m}</option>)}
                                </select>
                              </div>

                              <div className="col-span-1 xl:col-span-1">
                                <input type="number" min="1" value={row.qtdMaterial} onChange={(e) => handleUpdateRowValue(row.id, 'qtdMaterial', parseInt(e.target.value, 10) || 1)} className="w-full bg-black border border-slate-800 p-2 rounded text-xs text-center text-orange-400 font-bold h-9" />
                              </div>

                              <div className="col-span-1 xl:col-span-1 flex items-center justify-center gap-1.5">
                                <button type="button" onClick={() => handleRemoveRow(row.id)} className="bg-red-955/40 hover:bg-red-950 border border-red-900/40 text-red-400 p-2 rounded-lg text-xs">🗑️</button>
                              </div>

                            </div>

                            <div className="flex justify-start mt-1 pb-3 xl:pb-2">
                              <button type="button" onClick={() => handleAddRow(index)} className="text-[11px] text-sky-400 font-bold bg-sky-950/30 hover:bg-sky-950/60 px-3 py-1.5 rounded-lg border border-sky-900/30">➕ Incluir outra linha</button>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* Evidências Fotográficas e Envio */}
                    <div className="bg-slate-950 border border-slate-800 rounded-2xl p-5 shadow-xl space-y-4">
                      <h3 className="text-xs font-bold text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2">
                        📸 EVIDÊNCIAS E FECHAMENTO
                      </h3>

                      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div className="bg-slate-900 p-4 rounded-xl border border-slate-800 text-center space-y-3">
                          <span className="text-[10px] font-bold text-slate-400 block">CARREGAR FOTOS DE COMPROVAÇÃO DE CAMPO</span>
                          <div className="grid grid-cols-2 gap-2">
                            <button onClick={() => addMockPhoto('antes')} className="bg-slate-850 hover:bg-slate-800 text-[10px] py-2 rounded font-bold border border-slate-750">Antes</button>
                            <button onClick={() => addMockPhoto('depois')} className="bg-slate-850 hover:bg-slate-800 text-[10px] py-2 rounded font-bold border border-slate-750">Depois</button>
                          </div>
                          <div className="flex flex-wrap gap-2 justify-center">
                            {photosBefore.map(p => <img key={p.id} src={p.url} className="w-10 h-10 object-cover rounded border border-red-500/50" />)}
                            {photosAfter.map(p => <img key={p.id} src={p.url} className="w-10 h-10 object-cover rounded border border-emerald-500/50" />)}
                          </div>
                        </div>

                        <div className="space-y-4 flex flex-col justify-between">
                          <div className="space-y-2">
                            <label className="block text-xs font-semibold text-slate-400">⏱️ Duração do serviço de manutenção (Dias):</label>
                            <div className="flex items-center space-x-3 bg-slate-900 p-2 rounded-lg border border-slate-800">
                              <button onClick={() => setDurationDays(Math.max(1, durationDays - 1))} className="w-10 h-10 bg-slate-800 hover:bg-slate-700 text-lg font-bold rounded-lg">-</button>
                              <input type="number" value={durationDays} readOnly className="w-full bg-transparent text-center font-bold text-sm text-orange-400" />
                              <button onClick={() => setDurationDays(durationDays + 1)} className="w-10 h-10 bg-slate-800 hover:bg-slate-700 text-lg font-bold rounded-lg">+</button>
                            </div>
                          </div>

                          <div className="space-y-2">
                            <textarea value={observacao} onChange={(e) => setObservacao(e.target.value)} placeholder="Notas extras ou observações da execução..." className="w-full bg-slate-900 border border-slate-700 rounded-lg p-2.5 text-xs h-16 resize-none" />
                          </div>

                          <div className="flex items-center justify-between p-3 bg-slate-900 rounded-xl border border-slate-800">
                            <div>
                              <p className="text-xs font-bold">Assinatura Eletrônica</p>
                              <p className="text-[10px] text-slate-500">Validação Digital Administrativa</p>
                            </div>
                            {signature ? (
                              <span className="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold px-2.5 py-1 rounded">✅ Assinado</span>
                            ) : (
                              <button onClick={() => setSignature(true)} className="bg-orange-600 hover:bg-orange-500 text-white text-xs font-bold px-4 py-2 rounded-lg">✍️ Validar e Assinar</button>
                            )}
                          </div>
                        </div>
                      </div>
                    </div>

                    {/* Botões de Mesa */}
                    <div className="flex justify-end space-x-3 pt-4 border-t border-slate-800">
                      <button onClick={resetForm} className="bg-slate-850 hover:bg-slate-800 text-slate-300 font-bold px-6 py-3 rounded-xl border border-slate-750 text-xs">Limpar Tudo</button>
                      <button onClick={handleSubmitService} disabled={isSyncing} className="bg-emerald-600 hover:bg-emerald-500 font-bold px-8 py-3 rounded-xl text-xs text-white transition-all shadow-lg">
                        {isSyncing ? 'Sincronizando...' : 'Sincronizar Lançamento 📦'}
                      </button>
                    </div>

                  </div>

                </div>
              ) : (
                /* RECIBO FINAL IMPRESSO */
                <div className="max-w-3xl mx-auto bg-slate-950 border border-slate-800 rounded-2xl p-8 shadow-2xl space-y-6 animate-scaleUp">
                  
                  <div className="border-b border-slate-800 pb-6 flex justify-between items-start">
                    <div className="space-y-1">
                      <div className="bg-orange-600 text-white font-extrabold px-3 py-1 rounded text-sm tracking-wider inline-block">COMLURB RJ</div>
                      <h2 className="text-xl font-black">Ordem de Serviço de Manutenção e Vistoria de Praças</h2>
                      <p className="text-xs text-slate-400 font-medium">Setor de Parques, Praças e Parcões</p>
                    </div>
                    <div className="text-right">
                      <span className="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs font-bold px-3 py-1 rounded-full uppercase">Sincronizado</span>
                      <p className="text-[11px] text-slate-400 mt-2">ID OS: OS-{Math.floor(100000 + Math.random() * 900000)}</p>
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs text-slate-300">
                    <div className="space-y-2">
                      <p><strong className="text-slate-400">📋 Tipo de Entrada:</strong> {tipoEntrada} | <strong className="text-slate-400">📅 Data da Execução:</strong> {dataExecucao}</p>
                      <p><strong className="text-slate-400">📅 Programação:</strong> {semDataProgramacao ? "Sem data de programação" : dataProgramacao} | <strong className="text-slate-400">🛠️ Intervenção Geral:</strong> {intervencao || 'Não Selecionada'}</p>
                      <p><strong className="text-slate-400">📍 Localização:</strong> {selectedPraca?.nome} - {selectedPraca?.bairro}</p>
                      <p><strong className="text-slate-400">⏱️ Duração do Serviço:</strong> {durationDays} {durationDays === 1 ? 'Dia' : 'Dias'}</p>
                    </div>
                    <div className="space-y-2">
                      <p><strong className="text-slate-400">👥 Equipe Trabalhadora (Ergon):</strong> {selectedTeam.map(t => `${t.nome} (Matr: ${t.matricula})`).join(', ') || 'Nenhum'}</p>
                      <p><strong className="text-slate-400">🚛 Frota Registrada:</strong> {selectedFrota.map(f => `${f.prefixo} (${f.modelo})`).join(' | ') || 'Nenhum'}</p>
                      <p><strong className="text-slate-400">📝 Notas Extras:</strong> {observacao || 'Nenhuma.'}</p>
                      <p><strong className="text-slate-400">✍️ Responsável da Digitação:</strong> Carlos Alberto Silva</p>
                    </div>
                  </div>

                  {/* Vistorias feitas */}
                  <div className="bg-slate-900 border border-slate-850 rounded-xl p-4 space-y-3 text-xs">
                    <p className="font-bold text-slate-200">🔍 Diagnóstico de Intervenções Planejadas:</p>
                    <div className="grid grid-cols-2 gap-2 text-slate-300">
                      {Object.entries(inspectionStatus).map(([key, val]) => (
                        <div key={key} className="bg-slate-950 p-2 rounded border border-slate-855 flex justify-between">
                          <span className="font-medium text-[11px] truncate max-w-[65%]">{key}</span>
                          <span className="font-bold text-orange-400">{val}</span>
                        </div>
                      ))}
                      {Object.keys(inspectionStatus).length === 0 && <p className="text-slate-500 italic">Nenhuma intervenção registrada.</p>}
                    </div>
                  </div>

                  <div className="bg-slate-900 border border-slate-855 rounded-xl p-4 space-y-3">
                    <p className="text-xs font-bold text-slate-200">🛠️ Serviços e Materiais Aplicados:</p>
                    <table className="w-full text-left text-xs">
                      <thead>
                        <tr className="border-b border-slate-850 text-slate-400">
                          <th className="pb-2">Serviço (Qtd)</th>
                          <th className="pb-2">Item (Qtd)</th>
                          <th className="pb-2">Material (Qtd)</th>
                        </tr>
                      </thead>
                      <tbody>
                        {servicosMateriaisRows.map((r, index) => (
                          <tr key={index} className="border-b border-slate-800/40 last:border-0 text-slate-300">
                            <td className="py-2.5 font-medium">{r.servico || "—"} ({r.qtdServico})</td>
                            <td className="py-2.5 text-slate-400">{r.item || "—"} ({r.qtdItem})</td>
                            <td className="py-2.5 font-bold text-orange-400">{r.material || "—"} ({r.qtdMaterial})</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>

                  <div className="flex justify-between items-center pt-4 border-t border-slate-800">
                    <button onClick={() => window.print()} className="bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs font-bold py-2.5 px-5 rounded-xl border border-slate-700">🖨️ Imprimir Ordem de Serviço</button>
                    <button onClick={resetForm} className="bg-orange-600 hover:bg-orange-500 text-white text-xs font-bold py-2.5 px-6 rounded-xl shadow-md">Iniciar Novo Lançamento</button>
                  </div>

                </div>
              )}

            </main>
          )}

          {/* --- MODAL DE DETALHES DE CONFORMIDADE COM O TR --- */}
          {showComplianceModal && (
            <div className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
              <div className="bg-slate-900 border border-slate-700 rounded-2xl p-6 max-w-2xl w-full max-h-[80vh] overflow-y-auto space-y-4">
                <div className="flex justify-between items-center border-b border-slate-800 pb-3">
                  <h3 className="text-lg font-bold text-slate-100 flex items-center gap-2">📋 Rastreamento de Requisitos do Termo de Referência</h3>
                  <button onClick={() => setShowComplianceModal(false)} className="text-slate-400 hover:text-slate-100 font-extrabold text-lg">✕</button>
                </div>

                <div className="space-y-3">
                  <div className="bg-slate-950 p-3 rounded-xl border border-slate-800 flex gap-3 text-xs">
                    <span className="text-emerald-500 font-bold text-lg">✓</span>
                    <div>
                      <strong className="text-slate-200">Localização das Praças (ANEXO I):</strong>
                      <p className="text-slate-400 mt-1">O app usa geolocalização para sugerir a praça mais próxima de forma dinâmica.</p>
                    </div>
                  </div>
                  <div className="bg-slate-950 p-3 rounded-xl border border-slate-800 flex gap-3 text-xs">
                    <span className="text-emerald-500 font-bold text-lg">✓</span>
                    <div>
                      <strong className="text-slate-200">Cadastro de Itens de Vistoria (ANEXO II):</strong>
                      <p className="text-slate-400 mt-1">Checklist completo com brinquedos, mobiliários e cercas.</p>
                    </div>
                  </div>
                  <div className="bg-slate-950 p-3 rounded-xl border border-slate-800 flex gap-3 text-xs">
                    <span className="text-emerald-500 font-bold text-lg">✓</span>
                    <div>
                      <strong className="text-slate-200">Registro de Materiais (ANEXO IV):</strong>
                      <p className="text-slate-400 mt-1">Permite computar todos os consumos de campo, com cliques ou teclado.</p>
                    </div>
                  </div>
                </div>

                <div className="flex justify-end pt-2">
                  <button onClick={() => setShowComplianceModal(false)} className="bg-orange-600 hover:bg-orange-500 text-white font-bold text-xs py-2 px-4 rounded-lg">Entendi</button>
                </div>
              </div>
            </div>
          )}

          {/* --- FOOTER --- */}
          <footer className="bg-slate-950 border-t border-slate-800 text-slate-500 text-xs py-3 text-center shrink-0">
            <p>© 2026 COMLURB RJ - Divisão de Parques, Praças e Parcões. Protótipo de Alta Fidelidade.</p>
          </footer>

        </div>
      );
    }

    // Inicialização do React dentro do HTML único
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
