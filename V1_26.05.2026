      { cod: "1101002", nome: "INOMINADA - AVENIDA REPUBLICA DO CHILE - CENTRO", endereco: "AVENIDA REPUBLICA DO CHILE / RUA DO LAVRADIO, 75", bairro: "CENTRO", ap: "1", ugu: "UGU-S", tipo: "C" },
      { cod: "1101003", nome: "INOMINADA - AVENIDA REPUBLICA DO PARAGUAI - CENTRO", endereco: "AVENIDA REPUBLICA DO PARAGUAI, S/N / RUA DO REZENDE, 2", bairro: "CENTRO", ap: "1", ugu: "UGU-S", tipo: "C" },
