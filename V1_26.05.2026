    // --- CATALOGO ATUALIZADO BASEADO NAS PÁGINAS 4 A 6 DO CADERNO DE INTERVENÇÕES ---
    const ITENS_PRACA_MOCK = [
      { 
        id: 'cat-1', 
        categoria: 'Gradeamento & Cercas', 
